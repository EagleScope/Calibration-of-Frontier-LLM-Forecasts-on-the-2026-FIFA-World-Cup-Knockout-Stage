# ---- Secrets: NEVER commit ----
.env
.env.*
!.env.example
*.key
credentials
aws_credentials

# ---- Collected data (pre-registration TAG policy) ----
# TAG = protocol + scoring + frozen packs + ZERO model forecasts. The tag is created
# BEFORE any forecast run, so the tagged tree is forecast-free by construction.
# Live model forecasts: committed in per-round commits AFTER the tag (§17 timestamps);
#   tracked here (only pilot/throwaway logs ignored).
data/forecasts/pilot*
# Market-benchmark captures: GITIGNORED collected data, NOT in the tagged commit
#   (PI directive, item 5) — raw payload + UTC timestamp + SHA-256 stored on disk.
data/markets/*
# Pilot evidence kept OUT of the tagged tree (also retained in git history).
data/pilot/_local/
!data/**/.gitkeep

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ---- OS / editor ----
.DS_Store
*.swp
.idea/
.vscode/

# Demo/scoring artifacts
data/*.png

# throwaway scripts (not part of the study)
scripts/

# Throwaway Elo demo snapshot (real per-match snapshots are committed)
data/packs/elo_snapshots/demo/
